{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug PolyShopping API",
      "runtimeExecutable": "pnpm exec",
      "runtimeArgs": ["tsx", "--conditions", "source", "apps/api/src/main.ts"],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/tusky-backend/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    }
  ]
}
