    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^2.6.2",
    "tsx": "^4.21.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.2.6",
    "vitest": "^3.0.0"
  }
}
