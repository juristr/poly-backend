{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "emitDeclarationOnly": false,
    "types": ["node"],
    "rootDir": "src",
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "eslint.config.mjs",
    "eslint.config.js",
    "eslint.config.cjs"
  ],
  "references": [
    {
      "path": "../../packages/api-products/tsconfig.lib.json"
    }
  ]
}
